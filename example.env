# Server Configuration
PORT=3322
ADDRESS=0.0.0.0
NODE_ENV=development

# YouTube API Key (Optional - only needed for specific endpoints)
YOUTUBE_API_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=*

# Cache Configuration (in seconds)
CACHE_CHANNEL_TTL=600
CACHE_VIDEO_TTL=600